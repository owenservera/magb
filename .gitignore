# ── Build & Output ────────────────────────────────
dist/
build/
out/
.next/
*.tsbuildinfo
*.js.map

# ── Environment ───────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Database ──────────────────────────────────────
*.db
*.sqlite
*.sqlite3
guidebook.db

# ── Generated Knowledge Bases ─────────────────────
export/
output/
generated/

# ── Python ────────────────────────────────────────
