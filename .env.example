# magB Environment Variables

# ═══════════════════════════════════════════════════════════════
# Required Environment Variables
# ═══════════════════════════════════════════════════════════════

# Database Connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5433/magb

# Z.AI API Key (or your preferred LLM provider)
ZAI_API_KEY=your-api-key-here

# ═══════════════════════════════════════════════════════════════
# Optional Environment Variables
# ═══════════════════════════════════════════════════════════════

# Logging Configuration
# Levels: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Log File Path (optional, logs to console if not set)
# LOG_FILE=./logs/magb.log

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Rate Limiting (advanced)
# RATE_LIMIT_REQUESTS_PER_SECOND=2
# RATE_LIMIT_BURST=5

# Generation Configuration
# MAX_CONCURRENT_REQUESTS=10
# BUDGET_LIMIT_USD=50.0
# MAX_RETRIES=3

# ═══════════════════════════════════════════════════════════════
# Development vs Production
# ═══════════════════════════════════════════════════════════════

# Development (.env.local)
# - Use local database
# - Debug logging enabled
# - Lower rate limits for testing

# Production (.env.production)
# - Use production database
# - Info/Warn logging only
# - Production rate limits
# - Monitoring enabled

# ═══════════════════════════════════════════════════════════════
# Setup Instructions
# ═══════════════════════════════════════════════════════════════

# 1. Copy this file to .env.local
#    cp .env.example .env.local

# 2. Update DATABASE_URL with your PostgreSQL connection string
#    Default for Cloud SQL Proxy: postgresql://postgres:password@localhost:5433/magb

# 3. Add your Z.AI API key (or other LLM provider key)
#    ZAI_API_KEY=your-actual-api-key

# 4. (Optional) Configure logging and rate limiting

# 5. Run database migrations
#    bun run db:migrate

# 6. Seed the database (optional)
#    bun run db:seed

# 7. Start development server
#    bun run dev
